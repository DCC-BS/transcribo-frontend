{
    "name": "transcribo-frontend",
    "version": "1.1.2",
    "private": true,
    "scripts": {
        "dev": "nuxt dev",
        "build": "nuxt build",
        "start": "nuxt start",
        "generate": "nuxt generate",
        "lint": "biome check",
        "lint:fix": "biome check --fix",
        "format": "biome format --write",
        "check": "biome check --fix",
        "ci": "biome ci .",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "docker:dev": "docker compose -f ./docker-compose.dev.yml up --build -d",
        "docker:prod": "docker compose -f ./docker-compose.yml up --build -d",
        "docker:dev:down": "docker compose -f ./docker-compose.dev.yml down",
        "docker:prod:down": "docker compose -f ./docker-compose.yml down",
        "env:check": "bunx varlock load"
    },
    "dependencies": {
        "@dcc-bs/audio-recorder.bs.js": "2.1.3",
        "@dcc-bs/common-ui.bs.js": "^1.2.6",
        "@dcc-bs/communication.bs.js": "0.1.3",
        "@dcc-bs/event-system.bs.js": "^1.4.3",
        "@ffmpeg/ffmpeg": "^0.12.15",
        "@ffmpeg/util": "^0.12.2",
        "@iconify-json/lucide": "1.2.111",
        "@mohtasham/md-to-docx": "2.10.2",
        "@nuxt/ui": "4.8.2",
        "@nuxtjs/i18n": "10.4.0",
        "@nuxtjs/mdc": "0.22.0",
        "@vite-pwa/nuxt": "1.1.1",
        "@vueuse/core": "^14.3.0",
        "dexie": "^4.4.3",
        "driver.js": "^1.4.0",
        "konva": "10.3.0",
        "motion-v": "2.3.0",
        "nuxt": "4.4.8",
        "pino": "10.3.1",
        "ts-pattern": "^5.9.0",
        "uuid": "^14.0.0",
        "varlock": "^1.6.1",
        "vue": "3.5.38",
        "vue-konva": "3.4.0",
        "vue-tsc": "3.3.4",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@nuxt/test-utils": "^4.0.3",
        "@types/bun": "1.3.14",
        "@varlock/proton-pass-plugin": "^1.0.2",
        "@varlock/vite-integration": "^1.1.3",
        "@vitest/coverage-v8": "^4.1.8",
        "@vue/test-utils": "^2.4.11",
        "happy-dom": "20.10.2",
        "jiti": "^2.7.0",
        "msw": "^2.14.6",
        "pino-pretty": "^13.1.3",
        "sass": "1.100.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "overrides": {
        "vite": "7.3.5",
        "vue": "3.5.38"
    }
