{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "dependencyDashboard": true,
    "ignoreTests": false,
    "extends": ["config:recommended", ":prImmediately"],
    "internalChecksFilter": "strict",
    "minimumReleaseAge": "14 days",
    "packageRules": [
        {
            "matchDepTypes": ["devDependencies"],
            "matchPackageNames": ["lint", "prettier"],
            "automerge": true
        },
        {
            "matchUpdateTypes": ["minor", "patch"],
            "matchCurrentVersion": "!/^0/",
            "automerge": true
        },
        {
            "matchPackageNames": ["@mohtasham/md-to-docx"],
            "allowedVersions": "<2.11.0",
            "description": "Pin <2.11: 2.11+ imports node:net (secureImageFetch), breaks the browser build. Revisit when upstream makes it browser-safe."
        }
    ],
    "lockFileMaintenance": {
        "enabled": false
    }
}
